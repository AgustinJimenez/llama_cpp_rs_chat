# Environment Configuration for LLM Chat Application
# Copy this file to .env and modify values as needed
# Usage: ./run.sh (Unix/Linux/macOS) or run.bat (Windows)

# =============================================================================
# RUN MODE - Controls how the application runs
# =============================================================================
# Options: normal, debug_low, debug_high, build
# - normal:     Clean output (suppresses all logs for best user experience)
# - debug_low:  App debug messages only (LLAMA_DEBUG=true, LLAMA_LOG_LEVEL=4)
# - debug_high: All logs including LLaMA.cpp verbose output (LLAMA_LOG_LEVEL=0)
# - build:      Build the application only
RUN_MODE=normal

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Logging is now controlled by RUN_MODE above:
# - normal:     Clean output (no logs)
# - debug_low:  App debug messages only
# - debug_high: All logs including LLaMA.cpp verbose output

# =============================================================================
# SCRIPT BEHAVIOR
# =============================================================================
# Pause before exiting (useful for Windows double-click execution)
# true=pause, false=no pause (Unix scripts ignore this on false)
PAUSE_ON_EXIT=false

# =============================================================================
# MODEL CONFIGURATION (examples - customize for your setup)
# =============================================================================  
# MODEL_PATH=/path/to/your/model.gguf
# CONTEXT_SIZE=4096

# =============================================================================  
# QUICK SETUP EXAMPLES
# =============================================================================
# For clean user experience:          RUN_MODE=normal
# For app troubleshooting:            RUN_MODE=debug_low
# For deep troubleshooting:           RUN_MODE=debug_high
# For building only:                  RUN_MODE=build