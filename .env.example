# Environment Configuration for LLM Chat Application
# Copy this file to .env and modify values as needed
# Usage: ./run.sh (Unix/Linux/macOS) or run.bat (Windows)

# =============================================================================
# RUN MODE - Controls how the application runs
# =============================================================================
# Options: normal, silent, debug, build
# - normal: Standard execution with configured log levels
# - silent: Suppresses all stderr output (cleanest output)  
# - debug:  Shows all logs including verbose debug info
# - build:  Build the application only
RUN_MODE=normal

# =============================================================================
# BACKEND SELECTION
# =============================================================================
# Which backend to compile and use
# Options: llamacpp, candle
# - llamacpp: Use LLaMA.cpp backend (stable, supports GGUF files)
# - candle:   Use Candle backend (experimental, Rust-native)
BACKEND=llamacpp

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Backend-specific Logging Level (affects backend library logs)
# For LLaMA.cpp: 0=debug (most verbose), 1=info, 2=warn, 3=error (recommended), 4=none
# For Candle: Similar levels applied to Rust tracing
LOG_LEVEL=3

# Application Debug Mode (affects Rust application logs)
# Set to true/false or 1/0
APP_DEBUG=false

# =============================================================================
# SCRIPT BEHAVIOR
# =============================================================================
# Pause before exiting (useful for Windows double-click execution)
# true=pause, false=no pause (Unix scripts ignore this on false)
PAUSE_ON_EXIT=false

# =============================================================================
# MODEL CONFIGURATION (examples - customize for your setup)
# =============================================================================  
# MODEL_PATH=/path/to/your/model.gguf
# CONTEXT_SIZE=4096

# =============================================================================  
# QUICK SETUP EXAMPLES
# =============================================================================
# For LLaMA.cpp backend (stable):       BACKEND=llamacpp
# For Candle backend (experimental):    BACKEND=candle  
# For silent operation (no logs):       RUN_MODE=silent
# For troubleshooting (all logs):       RUN_MODE=debug  
# For development (balanced):           RUN_MODE=normal
# For building only:                    RUN_MODE=build